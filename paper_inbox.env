# ========================================
# Slack App
# ========================================
# Bot User OAuth Token (OAuth & Permissions)
# TokenはScrapboxへ
SLACK_BOT_TOKEN=xoxb-...

# App-Level Token with connections:write (Socket Mode)
SLACK_APP_TOKEN=xapp-...

# Botが監視するSlackチャンネルID
TARGET_CHANNEL_ID=...

# ========================================
# Slack List
# ========================================
# 対象リストのID
SLACK_LIST_ID=...

# Slack Listの各列ID
SLACK_COL_CITATION=...
SLACK_COL_TITLE=...
SLACK_COL_DOI_LINK=...
SLACK_COL_MEMO=...
SLACK_COL_MESSAGE=...

# ========================================
# Metadata APIs
# ========================================
# Crossref等への問い合わせ時の連絡先（推奨）
CONTACT_EMAIL=...

# ========================================
# Zotero
# ========================================
# Read/Write権限付きのPrivate API Key
ZOTERO_API_KEY=...

# Zoteroの数値User ID
ZOTERO_USER_ID=...

# 保存先コレクションのキー
ZOTERO_COLLECTION_KEY=...
